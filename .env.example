DATABASE_URL=postgresql://postgres:password@localhost:5432/wytui?schema=public
AUTH_SECRET=change-me-to-a-random-secret
AUTH_TRUST_HOST=true
ORIGIN=http://localhost:3000
NODE_ENV=development

